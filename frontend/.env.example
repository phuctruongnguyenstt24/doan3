# Địa chỉ contract Profile (đã có sẵn trong dự án)
VITE_CONTRACT_ADDRESS=0xYourProfileContractAddress

# Địa chỉ contract DonateVault (deploy bằng blockchain/scripts/deploy-donate.ts
# hoặc blockchain/ignition/modules/DonateVault.ts)
VITE_DONATE_CONTRACT_ADDRESS=0xYourDonateVaultAddress

# (Tuỳ chọn) RPC Sepolia dùng để đọc danh sách donate khi user chưa cài MetaMask
# Lấy free tại Alchemy/Infura, vd: https://eth-sepolia.g.alchemy.com/v2/xxxx
VITE_SEPOLIA_RPC_URL=
